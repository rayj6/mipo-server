# Server
PORT=3001
# Optional: base URL for strip and temp photo URLs (use your machine IP for device)
# BASE_URL=http://localhost:3001

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=mipo
DB_PASSWORD=your_password
DB_NAME=mipo

# Auth (use a long random string in production)
JWT_SECRET=your_jwt_secret_min_32_chars_long
# Optional: token expiry (default 7d)
# JWT_EXPIRES_IN=7d

# Optional: Remove.bg API key for background removal
# REMOVE_BG_API_KEY=
